<%- include("head.partial.ejs") %>

<main>
  <h1><%= title %></h1>
  <% if (category.recipes && category.recipes.length) { %>
    <ul id="recipes">
      <% category.recipes.forEach(function(recipe){ %>
        <li>
          <strong><a href="/przepisy/<%= category.slug %>/<%= recipe.id %>"><%= recipe.name %></a></strong>
           <div>Czas: <%= recipe.time %></div>

          <% if (user && (user.username === "admin" || Number(user.id) == Number(recipe.owner_id))) { %>
            <a href="/przepisy/<%= category.slug %>/edit/<%= recipe.id %>">Edytuj</a>

            <form action="/przepisy/<%= category.slug %>/delete/<%= recipe.id %>" method="POST" style="display:inline;margin-left:8px">
              <button type="submit" onclick="return confirm('Usuń przepis?')">Usuń</button>
            </form>
          <% } %>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p>Brak przepisów w tej kategorii.</p>
  <% } %>
</main>

<%- include("foot.partial.ejs") %>